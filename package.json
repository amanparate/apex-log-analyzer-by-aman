{
  "name": "apex-log-analyzer-by-aman",
  "displayName": "Apex Log Analyzer by Aman",
  "description": "Analyse Salesforce Apex debug logs with AI-assisted root-cause explanations, flame graphs, and SOQL-in-loop detection",
  "version": "0.2.0",
  "publisher": "aman",
  "engines": { "vscode": "^1.116.0" },
  "categories": ["Other", "Debuggers"],
  "keywords": ["salesforce", "apex", "log", "debug", "analyzer", "ai", "flame graph"],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      { "command": "apexLogAnalyzer.analyze", "title": "Analyse this Apex Log", "category": "Apex Log Analyzer" },
      { "command": "apexLogAnalyzer.fetchLog", "title": "Fetch Log from Salesforce", "category": "Apex Log Analyzer" },
      { "command": "apexLogAnalyzer.exportMarkdown", "title": "Export Analysis as Markdown", "category": "Apex Log Analyzer" },
      { "command": "apexLogAnalyzer.setApiKey", "title": "Set LLM API Key", "category": "Apex Log Analyzer" },
      { "command": "apexLogAnalyzer.startStream", "title": "Start Log Streaming", "category": "Apex Log Analyzer" },
      { "command": "apexLogAnalyzer.stopStream", "title": "Stop Log Streaming", "category": "Apex Log Analyzer" },
      { "command": "apexLogAnalyzer.compareLogs", "title": "Compare Two Apex Logs", "category": "Apex Log Analyzer" },
      { "command": "apexLogAnalyzer.clearApiKey", "title": "Clear LLM API Key", "category": "Apex Log Analyzer" }
    ],
    "menus": {
      "editor/context": [
        { "command": "apexLogAnalyzer.analyze", "group": "1_apexLogAnalyzer@1" }
      ],
      "commandPalette": [
        { "command": "apexLogAnalyzer.analyze" },
        { "command": "apexLogAnalyzer.fetchLog" },
        { "command": "apexLogAnalyzer.exportMarkdown" },
        { "command": "apexLogAnalyzer.setApiKey" },
        { "command": "apexLogAnalyzer.clearApiKey" },
        { "command": "apexLogAnalyzer.startStream" },
        { "command": "apexLogAnalyzer.stopStream" },
        { "command": "apexLogAnalyzer.compareLogs" }
      ]
    },
    "configuration": {
      "title": "Apex Log Analyzer by Aman",
      "properties": {
        "apexLogAnalyzer.provider": {
          "type": "string",
          "enum": ["openrouter", "anthropic"],
          "default": "openrouter",
          "description": "LLM provider. OpenRouter offers free models; Anthropic gives direct Claude access (paid)."
        },
        "apexLogAnalyzer.model": {
          "type": "string",
          "default": "openrouter/free",
          "description": "Model name. OpenRouter: 'openrouter/free' or any ':free' model. Anthropic: 'claude-sonnet-4-5'."
        },
        "apexLogAnalyzer.maxTokens": {
          "type": "number",
          "default": 1500,
          "description": "Maximum tokens for AI response."
        },
        "apexLogAnalyzer.soqlInLoopThreshold": {
          "type": "number",
          "default": 5,
          "description": "Flag SOQL-in-loop when the same query repeats at least this many times."
        },
        "apexLogAnalyzer.largeQueryThreshold": {
          "type": "number",
          "default": 1000,
          "description": "Flag a SOQL query as 'large' when it returns at least this many rows."
        },
        "apexLogAnalyzer.streamDebugLevel": {
        "type": "string",
        "default": "",
        "description": "Optional debug level to pass to 'sf apex tail log --debug-level'. Leave empty to stream with default trace flag."
      }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "npm run check-types && npm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "npm run check-types && npm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.116.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "esbuild": "^0.27.3",
    "npm-run-all": "^4.1.5",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}